DISABLE_ESLINT_PLUGIN=true
TSC_COMPILE_ON_ERROR=true
FAST_REFRESH=false

VITE_API_URL=http://localhost:8787

# JWT Secret for authentication (CHANGE THIS IN PRODUCTION!)
# This should match the secret in wrangler.toml for local development
VITE_JWT_SECRET=change-this-to-a-secure-random-secret-in-production
